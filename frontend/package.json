{
  "name": "frontend",
  "version": "0.0.1",
  "description": "A Quasar Project",
  "productName": "Telephony Toolbox",
  "author": "Michael Junek <michael@juneks.com.au>",
  "type": "module",
  "private": true,
  "scripts": {
    "lint": "prettier --write \"**/*.{js,vue,css,scss,html,md,json}\" --ignore-path .gitignore && eslint --fix -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "lint:check": "prettier --check \"**/*.{js,vue,css,scss,html,md,json}\" --ignore-path .gitignore && eslint -c ./eslint.config.js \"./src*/**/*.{js,cjs,mjs,vue}\"",
    "dev": "quasar dev",
    "build": "quasar build",
    "postinstall": "quasar prepare --silent"
  },
  "dependencies": {
    "@fontsource/fraunces": "^5.2.9",
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@quasar/extras": "^2.0.1",
    "axios": "^1.18.0",
    "pinia": "^3.0.4",
    "quasar": "^2.20.1",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@quasar/app-vite": "^3.0.0-rc.3",
    "@vue/eslint-config-prettier": "^10.2.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.4.0",
    "postcss": "^8.5.8",
    "prettier": "^3.8.1",
    "vite-plugin-checker": "^0.14.3",
    "vue-eslint-parser": "^10.4.1"
  },
  "keywords": [
    "quasar",
    "quasar-app",
    "quasar-cli",
    "quasar-app-vite",
    "vite",
    "vue",
    "vuejs"
  ],
  "engines": {
    "node": "^30 || ^28 || ^26 || ^24 || ^22.22.0"
  }
}
