DJANGO_SECRET_KEY=change-me
DJANGO_ALLOWED_HOSTS=telephony-toolbox.example.internal
DJANGO_DEBUG=false
CSRF_TRUSTED_ORIGINS=https://telephony-toolbox.example.internal,https://localhost:9000

DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=telephony_toolbox
DATABASE_USER=telephony_toolbox
DATABASE_PASSWORD=change-me

AUTH_MODE=entra
LOCAL_AUTH_ENABLED=true

CUCM_AXL_HOST=cucm.example.internal
CUCM_AXL_USERNAME=axl-user
CUCM_AXL_PASSWORD=change-me
CUCM_AXL_VERSION=14
CUCM_ROUTE_PARTITION=INTERNAL

AUDIT_RETENTION_DAYS=90

ENTRA_CLIENT_ID=
ENTRA_CLIENT_SECRET=
ENTRA_TENANT_ID=
ENTRA_REDIRECT_URI=https://telephony-toolbox.example.internal/api/auth/login/entra/callback/

LDAP_SERVER_URI=
LDAP_BIND_DN=
LDAP_BIND_PASSWORD=
LDAP_USER_SEARCH_BASE=
LDAP_USER_EMAIL_ATTRIBUTE=mail
LDAP_USER_DISPLAY_NAME_ATTRIBUTE=displayName
LDAP_USER_ENABLED_ATTRIBUTE=